listeners.tcp = none
listeners.ssl.default = 5671

ssl_options.cacertfile = /tmp/rabbitmq-secrets/rabbitmq_ca_cert
ssl_options.certfile = /tmp/rabbitmq-secrets/rabbitmq_server_cert
ssl_options.keyfile = /tmp/rabbitmq-secrets/rabbitmq_server_key
ssl_options.verify = verify_none
ssl_options.fail_if_no_peer_cert = false
